      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      justify-content: center;
      max-width: 700px;
      margin: 0 auto;
    }
    .market-chip {
      background: rgba(212,175,55,.1);
      border: 1px solid rgba(212,175,55,.3);
      color: var(--gold);
      font-weight: 600;
      font-size: 15px;
      padding: 12px 26px;
      border-radius: 99px;
      letter-spacing: .02em;
    }

    /* ── TESTIMONIAL / TRUST ── */
    .trust-row {
      display: flex;
      flex-wrap: wrap;
      gap: 20px;
      justify-content: center;
      max-width: 900px;
      margin: 0 auto;
    }
    .trust-card {
      background: var(--card);
      border: 1px solid rgba(212,175,55,.1);
      border-radius: 14px;
      padding: 28px 28px 24px;
      max-width: 280px;
      flex: 1;
      min-width: 220px;
    }
    .stars { color: var(--gold); font-size: 18px; margin-bottom: 12px; }
    .trust-card p { font-size: 14px; color: var(--muted); line-height: 1.7; margin-bottom: 16px; }
    .trust-name { font-weight: 600; font-size: 13px; color: var(--text); }

    /* ── SEBI BADGE ── */
    .sebi-banner {
      background: linear-gradient(135deg, rgba(34,197,94,.08) 0%, rgba(212,175,55,.08) 100%);
      border: 1px solid rgba(34,197,94,.25);
      border-radius: 14px;
      max-width: 680px;
      margin: 0 auto;
      padding: 34px 36px;
      display: flex;
      align-items: center;
      gap: 24px;
      flex-wrap: wrap;
    }
    .sebi-icon { font-size: 48px; }
    .sebi-text h3 {
      font-family: 'Playfair Display', serif;
      font-size: 22px;
      color: #fff;
      margin-bottom: 6px;
    }
    .sebi-text p { font-size: 14px; color: var(--muted); }

    /* ── CTA BOTTOM ── */
    .cta-section {
      background: linear-gradient(160deg, rgba(212,175,55,.12) 0%, transparent 60%);
      border-top: 1px solid rgba(212,175,55,.12);
      text-align: center;
      padding: 90px 24px;
    }
    .cta-section h2 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(28px, 5vw, 50px);
      font-weight: 900;
      color: #fff;
      margin-bottom: 18px;
      line-height: 1.12;
    }
    .cta-section h2 span { color: var(--gold); }
    .cta-section p { color: var(--muted); font-size: 16px; margin-bottom: 36px; }

    /* ── FOOTER ── */
    footer {
      background: var(--card);
      text-align: center;
      padding: 28px 24px;
      font-size: 13px;
      color: var(--muted);
      border-top: 1px solid rgba(212,175,55,.1);
    }
    footer a { color: var(--gold); text-decoration: none; }

    /* ── LIVE CALL TICKER ── */
    .live-calls {
      background: var(--navy);
      padding: 60px 24px;
    }
    .calls-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 16px;
      max-width: 900px;
      margin: 0 auto;
    }
    .call-card {
      background: var(--card);
      border-radius: 12px;
      padding: 20px 18px;
      border-left: 4px solid var(--green);
    }
    .call-card.loss { border-left-color: var(--red); }
    .call-instrument { font-size: 16px; font-weight: 700; color: #fff; margin-bottom: 4px; }
    .call-direction {
      font-size: 12px;
      font-weight: 700;
      letter-spacing: .06em;
      text-transform: uppercase;
      color: var(--green);
      margin-bottom: 8px;
    }
    .call-card.loss .call-direction { color: var(--red); }
    .call-return {
      font-family: 'Playfair Display', serif;
      font-size: 26px;
      font-weight: 800;
      color: var(--green);
    }
    .call-card.loss .call-return { color: var(--red); }
    .call-meta { font-size: 12px; color: var(--muted); margin-top: 4px; }

    @media (max-width: 600px) {
      nav { padding: 14px 18px; }
      .stat { min-width: 130px; }
      .sebi-banner { padding: 24px 20px; }
    }
  </style>
</head>
